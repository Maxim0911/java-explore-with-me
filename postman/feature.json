  "item": [
    {
      "name": "1. Create Comment",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
              "const jsonData = pm.response.json();",
              "pm.test(\"Has id\", () => pm.expect(jsonData).to.have.property('id'));",
              "pm.test(\"Has text\", () => pm.expect(jsonData).to.have.property('text'));",
              "pm.collectionVariables.set('commentId', jsonData.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"text\": \"Test comment from Postman\"\n}"
        },
